<section class="rr-section rr-contact rr-reveal" id="rr-contact">
  <div class="rr-section-inner">
    <div class="rr-label">{{ section.settings.contact_label | default: "05 — Contact" }}</div>
    <h2 class="rr-h2">{{ section.settings.contact_heading | default: "Let's" }} <em>{{ section.settings.contact_heading_italic | default: "Connect" }}</em></h2>
    <p class="rr-contact-sub">{{ section.settings.contact_sub | default: "Open to collaborations, freelance projects, and full-time opportunities." }}</p>

    <div class="rr-contact-grid">
      <div class="rr-contact-left">
        {% if section.settings.contact_email != blank %}
        <div class="rr-contact-card">
          <div class="rr-cc-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <div>
            <p class="rr-cc-label">Email</p>
            <p class="rr-cc-val">{{ section.settings.contact_email }}</p>
          </div>
        </div>
        {% endif %}
        {% if section.settings.contact_phone != blank %}
        <div class="rr-contact-card">
          <div class="rr-cc-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.4 2 2 0 0 1 3.6 1.22h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 21.73 16z"/></svg>
          </div>
          <div>
            <p class="rr-cc-label">Phone</p>
            <p class="rr-cc-val">{{ section.settings.contact_phone }}</p>
          </div>
        </div>
        {% endif %}
        <div class="rr-socials">
          {% if section.settings.github_url != blank %}
          <a href="{{ section.settings.github_url }}" target="_blank" class="rr-social-btn">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
            GitHub
          </a>
          {% endif %}
          {% if section.settings.linkedin_url != blank %}
          <a href="{{ section.settings.linkedin_url }}" target="_blank" class="rr-social-btn">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn
          </a>
          {% endif %}
        </div>
      </div>

      {% if section.settings.formspree_id != blank %}
      <form class="rr-form" action="https://formspree.io/f/{{ section.settings.formspree_id }}" method="POST">
        <div class="rr-form-row">
          <div class="rr-field">
            <label for="rr-name">{{ section.settings.form_name_label | default: "Name" }}</label>
            <input type="text" id="rr-name" name="name" placeholder="{{ section.settings.form_name_placeholder | default: 'Your name' }}" required>
          </div>
          <div class="rr-field">
            <label for="rr-email">{{ section.settings.form_email_label | default: "Email" }}</label>
            <input type="email" id="rr-email" name="email" placeholder="{{ section.settings.form_email_placeholder | default: 'your@email.com' }}" required>
          </div>
        </div>
        <div class="rr-field">
          <label for="rr-message">{{ section.settings.form_msg_label | default: "Message" }}</label>
          <textarea id="rr-message" name="message" rows="5" placeholder="{{ section.settings.form_msg_placeholder | default: 'Hi, I would love to work together...' }}" required></textarea>
        </div>
        <button type="submit" class="rr-btn rr-btn-primary rr-submit">
          <span>{{ section.settings.form_submit_text | default: "Send Message" }}</span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
        </button>
      </form>
      {% endif %}
    </div>
  </div>
</section>

<footer class="rr-footer">
  <div class="rr-footer-inner">
    <p>{{ section.settings.footer_copy | default: "© 2026 Portfolio — Built with passion & precision" }}</p>
    <div class="rr-footer-links">
      {% if section.settings.github_url != blank %}<a href="{{ section.settings.github_url }}" >GitHub</a>{% endif %}
      {% if section.settings.linkedin_url != blank %}<a href="{{ section.settings.linkedin_url }}">LinkedIn</a>{% endif %}
      {% if section.settings.contact_email != blank %}<a href="mailto:{{ section.settings.contact_email }}">Email</a>{% endif %}
    </div>
  </div>
</footer>

<style>
:root{--ink:#1a1410;--muted:#7c6e62;--cream:#faf7f2;--cream2:#f3ede3;--cream3:#ece4d8;--white:#ffffff;--amber:#c8842a;--amber2:#e09840;--rust:#b85c38;--sh:0 8px 40px rgba(200,132,42,.14);--sh2:0 24px 60px rgba(200,132,42,.22);--ease:cubic-bezier(.22,1,.36,1);}
body{font-family:'DM Sans',sans-serif;color:var(--ink);background:var(--cream);}
em{font-style:italic;font-family:'Playfair Display',serif;background:linear-gradient(135deg,var(--amber),var(--rust));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.rr-section{max-width:1180px;margin:24px auto;background:var(--white);border-radius:28px;padding:60px 64px;box-shadow:0 4px 32px rgba(26,20,16,.07);border:1px solid var(--cream3);transition:box-shadow .4s,transform .4s;}
.rr-section:hover{box-shadow:var(--sh2);transform:translateY(-3px);}
.rr-reveal{opacity:0;transform:translateY(40px);transition:opacity .7s var(--ease),transform .7s var(--ease);}
.rr-reveal.rr-in{opacity:1;transform:translateY(0);}
.rr-label{font-size:11px;font-weight:600;letter-spacing:3px;text-transform:uppercase;color:var(--amber);margin-bottom:8px;}
.rr-h2{font-family:'Playfair Display',serif;font-size:clamp(1.8rem,3vw,2.4rem);font-weight:800;color:var(--ink);margin-bottom:40px;letter-spacing:-.5px;position:relative;display:inline-block;}
.rr-h2::after{content:'';position:absolute;bottom:-10px;left:0;width:44px;height:3px;background:linear-gradient(90deg,var(--amber),transparent);border-radius:2px;transition:width .5s var(--ease);}
.rr-section:hover .rr-h2::after{width:100%;}
.rr-contact-sub{color:var(--muted);font-size:15px;margin-top:-28px;margin-bottom:36px;}
.rr-contact-grid{display:grid;grid-template-columns:1fr 1.7fr;gap:48px;align-items:start;}
.rr-contact-left{display:flex;flex-direction:column;gap:14px;}
.rr-contact-card{display:flex;align-items:center;gap:16px;background:linear-gradient(135deg,var(--cream),var(--cream2));border:1px solid var(--cream3);border-radius:16px;padding:18px 20px;transition:transform .35s var(--ease),box-shadow .35s,border-color .3s;}
.rr-contact-card:hover{transform:translateX(6px);box-shadow:var(--sh);border-color:rgba(200,132,42,.4);}
.rr-cc-icon{width:44px;height:44px;border-radius:12px;background:linear-gradient(135deg,var(--amber),var(--rust));color:#fff;flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:transform .3s,box-shadow .3s;}
.rr-contact-card:hover .rr-cc-icon{transform:rotate(-8deg) scale(1.08);box-shadow:0 4px 14px rgba(200,132,42,.4);}
.rr-cc-label{font-size:11px;color:#9a8878;font-weight:600;letter-spacing:.7px;text-transform:uppercase;}
.rr-cc-val{font-weight:600;color:var(--ink);font-size:14px;margin-top:2px;word-break:break-all;}
.rr-socials{display:flex;gap:10px;flex-wrap:wrap;margin-top:4px;}
.rr-social-btn{display:inline-flex;align-items:center;gap:8px;background:var(--ink);color:var(--cream);text-decoration:none;padding:10px 18px;border-radius:10px;font-size:13px;font-weight:600;transition:background .3s,transform .3s,box-shadow .3s;}
.rr-social-btn:hover{background:var(--amber);color:#fff;transform:translateY(-2px);box-shadow:0 6px 18px rgba(200,132,42,.35);}
.rr-form{display:flex;flex-direction:column;gap:16px;}
.rr-form-row{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
.rr-field{display:flex;flex-direction:column;gap:7px;}
.rr-field label{font-size:13px;font-weight:600;color:var(--ink);}
.rr-field input,.rr-field textarea{padding:12px 16px;border:1.5px solid var(--cream3);border-radius:12px;font-size:14px;font-family:'DM Sans',sans-serif;outline:none;background:var(--cream);color:var(--ink);transition:border-color .3s,background .3s,box-shadow .3s,transform .2s;width:100%;}
.rr-field input:focus,.rr-field textarea:focus{border-color:var(--amber);background:#fff;box-shadow:0 0 0 4px rgba(200,132,42,.1);transform:translateY(-1px);}
.rr-field textarea{resize:vertical;min-height:130px;}
.rr-btn{display:inline-flex;align-items:center;gap:9px;padding:13px 28px;border-radius:12px;font-size:14.5px;font-weight:600;text-decoration:none;transition:transform .3s,box-shadow .3s;cursor:pointer;border:none;letter-spacing:.2px;position:relative;overflow:hidden;font-family:'DM Sans',sans-serif;}
.rr-btn::before{content:'';position:absolute;inset:0;background:rgba(255,255,255,.08);opacity:0;transition:opacity .3s;}
.rr-btn:hover::before{opacity:1;}
.rr-btn-primary{background:linear-gradient(135deg,var(--amber) 0%,var(--rust) 100%);color:#fff;box-shadow:0 4px 20px rgba(200,132,42,.4);}
.rr-btn-primary:hover{transform:translateY(-3px);box-shadow:0 10px 32px rgba(200,132,42,.55);}
.rr-submit{width:100%;justify-content:center;font-size:15px;padding:14px;}
.rr-footer{background:var(--ink);color:#5a4e44;padding:36px 20px;margin-top:24px;}
.rr-footer-inner{max-width:1180px;margin:0 auto;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:16px;}
.rr-footer-inner p{font-size:13.5px;}
.rr-footer-links{display:flex;gap:20px;}
.rr-footer-links a{color:#5a4e44;text-decoration:none;font-size:13.5px;font-weight:600;transition:color .25s;}
.rr-footer-links a:hover{color:var(--amber2);}
@media(max-width:1024px){.rr-section{padding:50px 40px;}.rr-contact-grid{grid-template-columns:1fr;}}
@media(max-width:768px){.rr-section{padding:36px 24px;margin:16px auto;border-radius:20px;}.rr-h2{font-size:1.7rem;}.rr-form-row{grid-template-columns:1fr;}.rr-footer-inner{flex-direction:column;text-align:center;}}
@media(max-width:480px){.rr-section{padding:28px 18px;}.rr-contact-card{flex-direction:column;text-align:center;}.rr-cc-icon{margin:0 auto;}}
</style>

<script>
(function(){
  var revEls=document.querySelectorAll('.rr-reveal');
  var obs=new IntersectionObserver(function(entries){entries.forEach(function(e){if(e.isIntersecting){e.target.classList.add('rr-in');obs.unobserve(e.target);}});},{threshold:.08});
  revEls.forEach(function(el){obs.observe(el);});
  var form=document.querySelector('.rr-form');
  if(form) form.addEventListener('submit',function(){var btn=form.querySelector('.rr-submit span');if(btn){btn.textContent='Sending…';setTimeout(function(){btn.textContent='Send Message';},3000);}});
})();
</script>

{% schema %}
{
  "name": "Contact",
  "tag": "div",
  "settings": [
    {"type":"text","id":"contact_label","label":"Section Label","default":"05 — Contact"},
    {"type":"text","id":"contact_heading","label":"Heading","default":"Let's"},
    {"type":"text","id":"contact_heading_italic","label":"Heading (italic part)","default":"Connect"},
    {"type":"textarea","id":"contact_sub","label":"Sub-heading","default":"Open to collaborations, freelance projects, and full-time opportunities."},
    {"type":"text","id":"contact_email","label":"Email Address","default":"rathorerudrakshi03@gmail.com"},
    {"type":"text","id":"contact_phone","label":"Phone Number","default":"+91 7620136639"},
    {"type":"url","id":"github_url","label":"GitHub Profile URL"},
    {"type":"url","id":"linkedin_url","label":"LinkedIn Profile URL"},
    {"type":"text","id":"formspree_id","label":"Formspree Form ID","default":"mnjoygvv","info":"Get your form ID from formspree.io. Leave blank to hide the contact form."},
    {"type":"text","id":"form_name_label","label":"Form Name Label","default":"Name"},
    {"type":"text","id":"form_name_placeholder","label":"Form Name Placeholder","default":"Your name"},
    {"type":"text","id":"form_email_label","label":"Form Email Label","default":"Email"},
    {"type":"text","id":"form_email_placeholder","label":"Form Email Placeholder","default":"your@email.com"},
    {"type":"text","id":"form_msg_label","label":"Form Message Label","default":"Message"},
    {"type":"textarea","id":"form_msg_placeholder","label":"Form Message Placeholder","default":"Hi, I'd love to work together..."},
    {"type":"text","id":"form_submit_text","label":"Submit Button Text","default":"Send Message"},
    {"type":"text","id":"footer_copy","label":"Footer Copyright Text","default":"© 2026 Rudrakshi Rathore — Built with passion & precision"}
  ],
  "presets":[{"name":"Contact"}]
}
{% endschema %}
